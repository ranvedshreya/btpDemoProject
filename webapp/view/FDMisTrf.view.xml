<mvc:View controllerName="salesincentive.controller.FDMisTrf"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <Page>

        <customHeader>
            <Bar>
                <contentLeft>
                    <!-- <Image src="{headerModel>/logoPath}"
                    height="2.5rem" alt="Company Logo"
                    press="onLogoPress" decorative="false"/> -->

                    <Button 
                        icon="sap-icon://nav-back" 
                        press="onNavBack" 
                        type="Transparent" />
                    <Title text="Transaction and Flow Type-wise FD summary"/>
                    
                </contentLeft>
            </Bar>
        </customHeader>
        
        <ScrollContainer height="550px" vertical="true" horizontal="true">
            <Table id="FDTrfTable" class="productsTable"
                 sticky="ColumnHeaders"  noDataText="Loading...." >
                <columns>
                    <Column width="120px"> <Text text="Transaction"/> </Column>
                    <Column width="120px"> <Text text="Flow Type"/> </Column>
                    <Column width="120px"> <Text text="Bank Name"/> </Column>
                    <Column width="140px"> <Text text="Payer"/> </Column>
                    <Column width="140px"> <Text text="FD Number"/> </Column>
                    <Column width="120px"> <Text text="Term Start"/> </Column>
                    <Column width="120px"> <Text text="Term End"/> </Column>
                    <Column width="120px"> <Text text="Rate"/> </Column>
                    <Column width="120px"> <Text text="Annualised"/> </Column>
                    <Column width="120px"> <Text text="Tenor"/> </Column>
                    <Column width="140px"> <Text text="Investment Amount"/> </Column>
                    <Column width="140px"> <Text text="Maturity Amount"/> </Column>
                    <Column width="140px"> <Text text="Accrual Days"/> </Column>
                    <Column width="140px"> <Text text="Interest"/> </Column>
                    
                </columns>
                
            </Table>
        </ScrollContainer>
    </Page>
</mvc:View>