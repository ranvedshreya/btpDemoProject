<mvc:View xmlns:core="sap.ui.core" controllerName="salesincentive.controller.Home"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="homePageId" class="myBackground">
        <customHeader>
            <core:Fragment fragmentName="salesincentive.fragment.GlobalHeader" type="XML" />
        </customHeader>
        <GenericTile class="homeTile" header="Sales Summary" press="onPressTile"
         subheader="Product wise Sales Report">

            <TileContent>
                <core:Icon src="sap-icon://business-objects-experience" size="30px" height="100px" ></core:Icon>
            </TileContent>
            
        </GenericTile>

        <GenericTile class="homeTile" header="Sales Adjustment" press="onPressTile2"
         subheader="Collections Data">
            <TileContent>
                <core:Icon src="sap-icon://chart-table-view" size="30px" height="100px" ></core:Icon>
            </TileContent>
        </GenericTile>

        <GenericTile class="homeTile" header="FD MIS Summary" press="onPressTile3"
         subheader="Payer Wise and Transaction, Flow Type wise Report">
            <TileContent>
                <core:Icon src="sap-icon://business-objects-experience" size="30px" height="100px" ></core:Icon>
            </TileContent>
        </GenericTile>
        <GenericTile class="homeTile" header="Sales Details" press="onPressTile4"
         subheader="Sales Invoice Details">
            <TileContent>
                <core:Icon src="sap-icon://business-objects-experience" size="30px" height="100px" ></core:Icon>
            </TileContent>
        </GenericTile>
    </Page>
</mvc:View>