<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">

    <Dialog
        id="productChartDialog"
        title="Product-wise Net Value Distribution"
        contentWidth="700px"
        contentHeight="500px"
        resizable="true"
        draggable="true"
    >

        <content>
            <viz:VizFrame
                id="productChart"
                width="100%"
                height="400px"
                vizType="pie"
                vizProperties="{
                'legend': {
                    'isScrollable': true,
                    'visible': true
                }
                              
            }">

                <viz:dataset>
                    <viz.data:FlattenedDataset data="{/ZC_ProductDetailsSet}">
                        <viz.data:dimensions>
                            <viz.data:DimensionDefinition
                                name="Product"
                                value="{ProductDesc}" />
                        </viz.data:dimensions>

                        <viz.data:measures >
                            <viz.data:MeasureDefinition
                                name="Net Value"
                                value="{NetValue}" />
                        </viz.data:measures>
                    </viz.data:FlattenedDataset>
                </viz:dataset>

                

                <!-- Feeds for Pie Chart -->
                <viz:feeds>
                    <viz.feeds:FeedItem
                        uid="color"
                        type="Dimension"
                        values="Product" />

                    <viz.feeds:FeedItem
                        uid="size"
                        type="Measure"
                        values="Net Value" />
                </viz:feeds>

            </viz:VizFrame>
        </content>

        <endButton>
            <Button
                text="Close"
                press="onCloseChart" />
        </endButton>

    </Dialog>
</core:FragmentDefinition>
